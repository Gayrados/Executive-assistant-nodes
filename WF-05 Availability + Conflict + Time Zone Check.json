      "name": "Set - Executive Availability Result",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [940, 260]
    },
    {
      "parameters": {
        "content": "Time-zone validation.\n\nRules:\n- No finalization if missing or ambiguous zone\n- Convert into executive zone\n- Recheck DST and travel context\n- Include attendee-relevant zone for external meetings when useful",
        "height": 220,
        "width": 300,
        "color": 6
      },
      "id": "sticky_wf05_timezone",
