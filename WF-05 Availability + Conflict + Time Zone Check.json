        "timeMin": "={{$json.preferred_datetime}}",
        "timeMax": "={{new Date(new Date($json.preferred_datetime).getTime() + ($json.duration_minutes * 60000)).toISOString()}}",
        "returnAll": true
      },
      "id": "google_wf05_exec_calendar",
      "name": "Google Calendar - Check Executive Availability",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [700, 260],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "GOOGLE_CALENDAR_CREDENTIAL_PLACEHOLDER",
          "name": "GOOGLE_CALENDAR_CREDENTIAL_PLACEHOLDER"
        }
      }
    },
    {
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "executive_window_status",
