      "parameters": {
        "content": "WF-04 Priority + Urgency Classification\n\nPurpose:\nAssign priority, urgency, internal/external class, and confidentiality/privacy class using the Thinker and Executioner rules.\n\nCoverage:\n- Priority classification\n- Urgency validation\n- Internal vs external classification\n- Confidentiality/privacy classification\n- False urgency handling\n- Approval flagging\n- Error branch",
        "height": 280,
        "width": 340,
        "color": 4
      },
      "id": "sticky_wf04_intro",
      "name": "Sticky Note - WF-04 Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [20, 40]
    },
    {
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "wf_name",
              "value": "WF-04 Priority + Urgency Classification"
            },
            {
              "name": "status",
              "value": "IN_PROGRESS"
            },
            {
              "name": "status_log_wf04_01",
              "value": "WF-04 started business priority and urgency classification."
            }
          ]
        }
      },
      "id": "set_wf04_start",
      "name": "Set - Start WF-04",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [420, 340]
    },
    {
      "parameters": {
        "content": "Priority rules:\n- Critical/Urgent: crisis, legal, compliance, safety, board emergency, executive-critical deadline\n- High: leadership, board, investor, VIP, strategic, major client/vendor/partner\n- Normal: routine business meetings\n- Low: informational, optional, low-consequence\n- Tentative/Pending: missing purpose, agenda, logistics, confirmation, or unclear executive need",
        "height": 260,
        "width": 340,
        "color": 6
      },
      "id": "sticky_wf04_priority",
      "name": "Sticky Note - Priority Rules",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [620, 40]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "string": [
                  {
                    "value1": "={{$json.priority_signal || ''}}",
                    "operation": "regex",
                    "value2": "(crisis|legal|compliance|safety|board emergency|executive-critical)"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "critical"
            },
            {
              "conditions": {
                "string": [
                  {
                    "value1": "={{$json.priority_signal || $json.meeting_type || ''}}",
                    "operation": "regex",
                    "value2": "(leadership|board|investor|vip|strategic|client|vendor|partner)"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "high"
            },
            {
              "conditions": {
                "string": [
                  {
                    "value1": "={{$json.meeting_purpose || ''}}",
                    "operation": "isEmpty"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "tentative"
            }
          ]
        },
        "fallbackOutput": "normal"
      },
