      "parameters": {
        "content": "Urgency rules:\n- Immediate/Same Day only if evidence-based\n- This Week for real near-term pressure\n- Scheduled/Normal if planned\n- Flexible if easily movable\n- False Urgency/Unclear if unsupported",
        "height": 220,
        "width": 300,
        "color": 5
      },
      "id": "sticky_wf04_urgency",
      "name": "Sticky Note - Urgency Rules",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1460, 40]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "string": [
                  {
                    "value1": "={{$json.urgency_signal || ''}}",
                    "operation": "regex",
                    "value2": "(same day|immediate|today|asap)"
                  }
                ],
                "boolean": [
                  {
                    "value1": "={{$json.urgency_validated === true || $json.urgency_validated === 'true'}}",
                    "operation": "isTrue"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "immediate"
            },
            {
              "conditions": {
                "string": [
                  {
                    "value1": "={{$json.urgency_signal || ''}}",
                    "operation": "regex",
                    "value2": "(this week|week)"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "this_week"
            },
            {
              "conditions": {
                "boolean": [
                  {
                    "value1": "={{$json.false_urgency === true || $json.false_urgency === 'true'}}",
                    "operation": "isTrue"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "false_urgency"
            }
          ]
        },
        "fallbackOutput": "scheduled"
      },
